{% extends 'lindemannrock-base/_layouts/cp-table' %}

{# All filter / sort / pagination state is computed in
   ApiKeysController::actionIndex(); this template stays presentational and
   just renders what's handed in. #}

{% set columns = [
    {key: 'name', label: 'Name'|t('formie-rest-api'), sortable: true},
    {key: 'status', label: 'Status'|t('formie-rest-api'), sortable: true},
    {key: 'prefix', label: 'Prefix'|t('formie-rest-api'), sortable: false},
    {key: 'allowedForms', label: 'Allowed forms'|t('formie-rest-api'), sortable: true, hideable: true},
    {key: 'signing', label: 'Signing'|t('formie-rest-api'), sortable: false, hideable: true},
    {key: 'validUntil', label: 'Expires'|t('formie-rest-api'), sortable: true, hideable: true},
    {key: 'lastUsedAt', label: 'Last used'|t('formie-rest-api'), sortable: true, hideable: true},
] %}

{% set tableConfig = {
    plugin: {
        handle: 'formie-rest-api',
        name: formieRestApiHelper.fullName,
    },
    page: {
        title: 'API Keys'|t('formie-rest-api'),
        subnav: 'api-keys',
        crumbs: [
            { label: formieRestApiHelper.fullName, url: url('formie-rest-api') },
            { label: 'API Keys'|t('formie-rest-api'), url: url('formie-rest-api') },
        ],
    },
    filters: [
        {
            type: 'status',
            param: 'status',
            current: statusFilter,
            label: 'All'|t('formie-rest-api'),
            groups: [
                {
                    param: 'status',
                    current: statusFilter,
                    colorSet: 'status',
                    options: [
                        {value: 'all', label: 'All'|t('formie-rest-api'), status: 'all'},
                        {value: 'enabled', label: 'Enabled'|t('formie-rest-api'), colorKey: 'enabled'},
                        {value: 'disabled', label: 'Disabled'|t('formie-rest-api'), colorKey: 'disabled'},
                    ],
                },
            ],
        },
    ],
    search: {
        placeholder: 'Search API keys...'|t('formie-rest-api'),
        value: search,
    },
    sort: {
        field: sort,
        direction: dir,
    },
    table: {
        columns: columns,
        items: keys,
        emptyMessage: 'No API keys yet.'|t('formie-rest-api'),
    },
    pagination: {
        page: page,
        limit: limit,
        totalCount: totalCount,
        itemLabel: {
            singular: 'API key'|t('formie-rest-api'),
            plural: 'API keys'|t('formie-rest-api'),
        },
    },
    newButton: canCreate ? {
        url: url('formie-rest-api/api-keys/create'),
        label: 'New API Key'|t('formie-rest-api'),
    } : null,
    checkboxes: canEdit or canRevoke,
    rowActions: canEdit or canRevoke,
} %}

{% block beforeTable %}
    {% if not hasAnyKeys %}
        {% set warningMessage %}
        {{ 'No API keys have been created yet. Create a key per consumer to control access to the REST API.'|t('formie-rest-api') }}
        {% endset %}
        <div class="lr-info-box-table-wrapper">
            {% include 'lindemannrock-base/_components/info-box' with {
                message: warningMessage,
                type: 'info',
                margin: 'none',
                stretch: true,
            } %}
        </div>
    {% endif %}
{% endblock %}

{% block tableRow %}
    <td data-column="name">
        {% if canEdit %}
            <a href="{{ url('formie-rest-api/api-keys/edit/' ~ item.id) }}">{{ item.name }}</a>
        {% else %}
            {{ item.name }}
        {% endif %}
    </td>

    <td data-column="status">
        {% set status = item.getStatus() %}
        {% set statusLabel = {
            'active': 'Enabled'|t('formie-rest-api'),
            'disabled': 'Disabled'|t('formie-rest-api'),
            'expired': 'Expired'|t('formie-rest-api'),
        }[status] %}
        {# Map our model statuses to the base `status` colorSet keys: Active
           reuses the 'enabled' (teal) slot; Disabled and Expired map 1:1. #}
        {% set statusColorKey = {'active': 'enabled', 'disabled': 'disabled', 'expired': 'expired'}[status] %}
        {% include 'lindemannrock-base/_components/badge' with {
            label: statusLabel,
            value: statusColorKey,
            colorSet: 'status',
        } only %}
    </td>

    <td data-column="prefix">
        <code>{{ item.keyPrefix }}...</code>
    </td>

    <td data-column="allowedForms">
        {% if item.allowsAllForms() %}
            <span class="light">{{ 'All Forms'|t('formie-rest-api') }}</span>
        {% elseif item.allowedForms|length == 0 %}
            <span class="light" title="{{ 'No forms allowed — this key cannot be used until you add some.'|t('formie-rest-api') }}">{{ 'None'|t('formie-rest-api') }}</span>
        {% else %}
            {{ item.allowedForms|length }} {{ item.allowedForms|length == 1 ? 'form'|t('formie-rest-api') : 'forms'|t('formie-rest-api') }}
        {% endif %}
    </td>

    <td data-column="signing">
        {% include 'lindemannrock-base/_components/badge' with {
            label: item.requireSignature ? 'Enabled'|t('formie-rest-api') : 'Disabled'|t('formie-rest-api'),
            value: item.requireSignature ? 'enabled' : 'disabled',
            colorSet: 'status',
        } only %}
    </td>

    <td data-column="validUntil">
        {% if item.validUntil %}
            {% if not item.isStillValid() %}
                <span class="lr-text-red" title="{{ 'Expired'|t('formie-rest-api') }}">{{ item.validUntil|lrDatetime }}</span>
            {% else %}
                {{ item.validUntil|lrDatetime }}
            {% endif %}
        {% else %}
            <span class="light">{{ 'Never'|t('formie-rest-api') }}</span>
        {% endif %}
    </td>

    <td data-column="lastUsedAt">
        {{ item.lastUsedAt ? item.lastUsedAt|lrDatetime : '—' }}
    </td>
{% endblock %}

{% block bulkActions %}
    {% if canEdit %}
        {% include 'lindemannrock-base/_components/bulk-status-menu' with {
            label: 'Set status'|t('formie-rest-api'),
            countId: 'lr-bulk-status-count',
            items: [
                {id: 'lr-bulk-enable-action', label: 'Enable'|t('formie-rest-api'), status: 'enabled'},
                {id: 'lr-bulk-disable-action', label: 'Disable'|t('formie-rest-api'), status: 'disabled'},
            ],
        } only %}
    {% endif %}

    {% if canRevoke %}
        {% include 'lindemannrock-base/_components/bulk-actions-menu' with {
            label: 'Actions'|t('formie-rest-api'),
            countId: 'lr-bulk-actions-count',
            items: [
                {id: 'lr-bulk-revoke-btn', label: 'Revoke'|t('formie-rest-api'), class: 'error'},
            ],
        } only %}
    {% endif %}
{% endblock %}

{% block rowActions %}
    {% set actionItems = [] %}

    {% if canEdit %}
        {% set actionItems = actionItems|merge([{
            label: 'Edit'|t('formie-rest-api'),
            url: url('formie-rest-api/api-keys/edit/' ~ item.id),
        }]) %}
    {% endif %}

    {% if canRevoke %}
        {% if canEdit %}
            {% set actionItems = actionItems|merge([{type: 'divider'}]) %}
        {% endif %}
        {# No `confirm:` on the action item — confirmation is handled in the
           JS handler below as the single source of truth. Putting it in both
           places risks a double prompt if any layer (Craft CP / base
           component) decides to honour `data-confirm` natively. #}
        {% set actionItems = actionItems|merge([{
            label: 'Revoke'|t('formie-rest-api'),
            class: 'error',
            jsAction: 'revoke',
        }]) %}
    {% endif %}

    {% if actionItems|length %}
        {% include 'lindemannrock-base/_components/row-actions' with {
            item: {id: item.id},
            actions: {
                type: 'menu',
                icon: 'settings',
                title: 'Actions'|t('formie-rest-api'),
                items: actionItems,
            },
        } only %}
    {% endif %}
{% endblock %}

{% block scripts %}
<script>
(function() {
    if (typeof Craft === 'undefined') return;

    // Pre-translated strings: keep |t() in Twig (so they're translatable)
    // and emit as JSON-encoded JS literals via |json_encode|raw — avoids
    // the |e('js') trap (produces \uXXXX garbage when re-quoted).
    const T = {
        revokeConfirm: {{ 'Are you sure you want to revoke this API key? Any callers using it will immediately lose access.'|t('formie-rest-api')|json_encode|raw }},
        revokeFailed: {{ 'Couldn’t revoke API key'|t('formie-rest-api')|json_encode|raw }},
        bulkEnableFailed: {{ 'Couldn’t enable API keys'|t('formie-rest-api')|json_encode|raw }},
        bulkDisableFailed: {{ 'Couldn’t disable API keys'|t('formie-rest-api')|json_encode|raw }},
        bulkRevokeFailed: {{ 'Couldn’t revoke API keys'|t('formie-rest-api')|json_encode|raw }},
        // Two strings rendered server-side; JS picks by count and substitutes
        // the placeholder. Avoids ICU-plural syntax in this template entirely.
        bulkRevokeConfirmSingular: {{ 'Are you sure you want to revoke 1 API key? Any callers using it will immediately lose access. This cannot be undone.'|t('formie-rest-api')|json_encode|raw }},
        bulkRevokeConfirmPlural: {{ 'Are you sure you want to revoke {count} API keys? Any callers using them will immediately lose access. This cannot be undone.'|t('formie-rest-api')|json_encode|raw }},
    };

    // ---------------------------------------------------------------------
    // Per-row action handlers (Revoke). The base row-actions component
    // renders each action item as `<a data-action="<jsAction>" data-id>`.
    // Hook `[data-action]` anchors, scope by the action value, do confirm
    // here (no `confirm:` on the action item — single source of truth).
    // ---------------------------------------------------------------------
    document.addEventListener('click', function(e) {
        const trigger = e.target.closest('a[data-action]');
        if (!trigger) return;
        if (trigger.dataset.action !== 'revoke') return;
        const id = parseInt(trigger.dataset.id || '0', 10);
        if (!id) return;
        e.preventDefault();

        if (!confirm(T.revokeConfirm)) return;

        Craft.sendActionRequest('POST', 'formie-rest-api/api-keys/delete', {
            data: {keyId: id},
        }).then(function() {
            window.location.reload();
        }).catch(function() {
            Craft.cp.displayError(T.revokeFailed);
        });
    });

    function selectedIds() {
        return window.lrTableSelection ? window.lrTableSelection.getSelectedIds() : [];
    }

    // Bulk handlers share this helper: same POST shape (`ids: [...]`), same
    // success behaviour (reload), same failure UX (Craft.cp.displayError).
    function runBulkStatus(endpoint, errorFallback) {
        const ids = selectedIds();
        if (!ids.length) return;
        Craft.sendActionRequest('POST', endpoint, {data: {ids: ids}})
            .then(function() { window.location.reload(); })
            .catch(function() { Craft.cp.displayError(errorFallback); });
    }

    document.getElementById('lr-bulk-enable-action')?.addEventListener('click', function(e) {
        e.preventDefault();
        runBulkStatus('formie-rest-api/api-keys/bulk-enable', T.bulkEnableFailed);
    });

    document.getElementById('lr-bulk-disable-action')?.addEventListener('click', function(e) {
        e.preventDefault();
        runBulkStatus('formie-rest-api/api-keys/bulk-disable', T.bulkDisableFailed);
    });

    document.getElementById('lr-bulk-revoke-btn')?.addEventListener('click', function() {
        const ids = selectedIds();
        if (!ids.length) return;
        const confirmMessage = ids.length === 1
            ? T.bulkRevokeConfirmSingular
            : T.bulkRevokeConfirmPlural.replace('{count}', String(ids.length));
        if (!confirm(confirmMessage)) return;
        runBulkStatus('formie-rest-api/api-keys/bulk-delete', T.bulkRevokeFailed);
    });
})();
</script>
{% endblock %}
