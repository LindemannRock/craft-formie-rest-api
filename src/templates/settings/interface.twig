{% extends "formie-rest-api/_layouts/settings" %}
{% set title = 'Interface Settings'|t('formie-rest-api') %}
{% set fullPageForm = true %}
{% set selectedSettingsItem = 'interface' %}

{% set crumbs = [
    {
        label: 'Settings'|t('formie-rest-api'),
        url: cpUrl('settings'),
    },
    {
        label: 'Plugins'|t('formie-rest-api'),
        url: cpUrl('settings/plugins'),
    },
    {
        label: formieRestApiHelper.fullName|t('formie-rest-api'),
        url: cpUrl('formie-rest-api/settings'),
    },
    {
        label: 'Interface'|t('formie-rest-api'),
        url: cpUrl('formie-rest-api/settings/interface'),
    },
] %}

{% block content %}
    {{ actionInput('formie-rest-api/settings/save') }}
    {{ redirectInput('formie-rest-api/settings/interface') }}
    {{ hiddenInput('section', 'interface') }}

        {% include 'lindemannrock-base/_partials/cascade-base-overrides' with {
            settings: settings,
            pluginHandle: 'formie-rest-api',
            sections: {
                dateFormat: {},
            },
        } only %}

    {% include 'lindemannrock-base/_components/plugin-credit' %}
{% endblock %}
