{#
  Missing API Keys Warning Partial

  Shows an admin error banner when no API keys are configured in .env.
  Plugin is unusable until at least FORMIE_API_KEY is set.

  Usage:
    {% set missingKeysSummary = include('formie-rest-api/_partials/missing-keys-warning')|trim %}
#}

{% set frPlugin = craft.app.plugins.getPlugin('formie-rest-api') %}
{% set keyCount = frPlugin ? frPlugin.apiKey.getValidApiKeys()|length : 0 %}

{% if keyCount == 0 %}
    <div class="error-summary" tabindex="-1" style="margin-bottom: 24px;">
        <div>
            <span class="notification-icon" data-icon="alert" aria-label="{{ 'error'|t('formie-rest-api') }}" role="img"></span>
            <h2>{{ 'Configuration Required'|t('formie-rest-api') }}</h2>
        </div>
        <ul class="errors">
            <li>
                <strong>{{ 'No API keys configured.'|t('formie-rest-api') }}</strong> {{ 'The plugin will reject every request until at least one key is set.'|t('formie-rest-api') }}
                <br><br>
                <strong>{{ 'Run one of these commands in your terminal:'|t('formie-rest-api') }}</strong>
                <br><br>

                <div>
                    <div style="margin-bottom: 12px;">
                        <strong style="font-size: 13px; color: #596673; display: block; margin-bottom: 4px;">{{ 'Standard:'|t('formie-rest-api') }}</strong>
                        <div style="position: relative; display: flex; align-items: center; gap: 8px;">
                            <code id="frapi-cmd-normal" style="background: #f9fafb; padding: 10px 12px; border-radius: 4px; flex: 1; border: 1px solid #e5e7eb; font-size: 13px; font-family: 'SFMono-Regular', Consolas, 'Liberation Mono', Menlo, monospace;">php craft formie-rest-api/security/generate-key all</code>
                            <button type="button" onclick="frapiCopyCmd('frapi-cmd-normal', this)" style="background: #0d78f2; color: white; border: none; padding: 10px 16px; border-radius: 4px; cursor: pointer; font-size: 12px; font-weight: 600; white-space: nowrap;">{{ 'COPY'|t('formie-rest-api') }}</button>
                        </div>
                    </div>

                    <div>
                        <strong style="font-size: 13px; color: #596673; display: block; margin-bottom: 4px;">{{ 'DDEV:'|t('formie-rest-api') }}</strong>
                        <div style="position: relative; display: flex; align-items: center; gap: 8px;">
                            <code id="frapi-cmd-ddev" style="background: #f9fafb; padding: 10px 12px; border-radius: 4px; flex: 1; border: 1px solid #e5e7eb; font-size: 13px; font-family: 'SFMono-Regular', Consolas, 'Liberation Mono', Menlo, monospace;">ddev craft formie-rest-api/security/generate-key all</code>
                            <button type="button" onclick="frapiCopyCmd('frapi-cmd-ddev', this)" style="background: #0d78f2; color: white; border: none; padding: 10px 16px; border-radius: 4px; cursor: pointer; font-size: 12px; font-weight: 600; white-space: nowrap;">{{ 'COPY'|t('formie-rest-api') }}</button>
                        </div>
                    </div>
                </div>

                <br>
                {{ 'This will write {keys} and matching signing secrets to your {file} file.'|t('formie-rest-api', {
                    keys: '<code>FORMIE_API_KEY</code>, <code>FORMIE_API_KEY_LIMITED</code>, <code>FORMIE_API_KEY_TEST</code>',
                    file: '<code>.env</code>',
                })|raw }}
                <br>
                <strong style="color: #d97706;">{{ 'Warning:'|t('formie-rest-api') }}</strong> {{ 'Generate separate keys per environment — never copy production keys to staging or development.'|t('formie-rest-api') }}

                <script>
                    function frapiCopyCmd(elementId, btn) {
                        var text = document.getElementById(elementId).textContent;
                        navigator.clipboard.writeText(text).then(function() {
                            var original = btn.textContent;
                            btn.textContent = {{ 'COPIED'|t('formie-rest-api')|json_encode|raw }};
                            btn.style.background = '#16a34a';
                            setTimeout(function() {
                                btn.textContent = original;
                                btn.style.background = '#0d78f2';
                            }, 1500);
                        });
                    }
                </script>
            </li>
        </ul>
    </div>
{% endif %}
