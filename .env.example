# Formie REST API — Environment Variables
#
# Each environment (local / staging / production) has its own .env file
# with its own unique values for these variables. Use the CLI to generate
# secure keys:
#
#   ddev craft formie-rest-api/security/generate-key   (local)
#   php craft formie-rest-api/security/generate-key    (staging / production)
#
# The CLI prompts whether to write to .env or just print the key (for hosting
# panel / secret store).

# Primary key — full read/write access (read forms, read submissions, create submissions)
FORMIE_API_KEY=

# Limited key — read forms only (optional)
FORMIE_API_KEY_LIMITED=

# Test key — only valid when devMode=true (optional, local only)
FORMIE_API_KEY_TEST=

# Notes:
# • Use DIFFERENT values per environment — never share keys across local/staging/prod
# • Never commit .env to version control
# • Store keys in a password manager or secrets vault
# • Rotate periodically (e.g. every 90 days, or immediately on suspected leak)
# • Send to the API via the X-API-Key request header

